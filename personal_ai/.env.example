# ============================================================
# PersonalAIBotV2 — Personal AI Bot Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── AI Provider ─────────────────────────────────────────────
# Required: Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Telegram Bot ────────────────────────────────────────────
# Required for Telegram: get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── LINE Bot ─────────────────────────────────────────────────
# Required for LINE: get from LINE Developers Console
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# ── Server ──────────────────────────────────────────────────
# Port for LINE webhook server
PORT=3001

# ── Optional ────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
MINIMAX_API_KEY=your_minimax_api_key_here
