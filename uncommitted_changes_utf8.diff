+function normalizeBridgeOutput(text: unknown): string {
+  const normalized = String(text || '').replace(/\r\n/g, '\n').trim();
+  const outputMaxChars = getVoiceToolBridgeOutputMaxChars();
+  if (!normalized) return 'No response from Jarvis Agent.';
+  const sanitized = sanitizeForLiveApi(normalized);
+  if (sanitized.length <= outputMaxChars) return sanitized;
+  // Truncate at a safe boundary (avoid mid-character cut in multi-byte scripts)
+  let cutPoint = outputMaxChars;
+  while (cutPoint > 0 && isHighSurrogate(sanitized.charCodeAt(cutPoint - 1))) cutPoint--;
+  return `${sanitized.slice(0, cutPoint)}\n...[truncated]`;
