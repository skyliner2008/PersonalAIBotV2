+  const directCandidate = fromMarkdown || trimmed;
+
+  const candidates: string[] = [directCandidate];
+  const firstLine = directCandidate.split(/\r?\n/)[0]?.trim();
+  if (firstLine && firstLine !== directCandidate) {
+    candidates.push(firstLine);
+  }
