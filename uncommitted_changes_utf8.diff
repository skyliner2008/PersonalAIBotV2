+    if (this.shouldSkipReviewerGateForMode(chatId)) {
+      return draftReply;
+    }
+
+    if (!shouldRunReviewerGate(taskType, draftReply, stats.turns, stats.toolCalls.length)) {
+      return draftReply;
+    }
+
+    // Avoid extra reviewer traffic when provider is currently rate-limited.
+    if (this.isProviderCoolingDown(providerName)) {
+      return draftReply;
+    }
+
+    const trackedPlanCtx = this.buildTrackedPlanContext(chatId);
+    const reviewPrompt = [
+      'Review the draft reply for correctness, completeness, and alignment with the user request.',
+      'Return exactly:',
+      'VERDICT: PASS or REVISE',
+      'ISSUES:',
+      '- short issue',
+      'REVISED_REPLY:',
+      '<only when REVISE>',
+      '',
+      '[User Request]',
+      userMessage,
+      trackedPlanCtx ? trackedPlanCtx.trim() : '',
+      '',
+      '[Draft Reply]',
+      draftReply.length > REVIEW_CONTEXT_LIMIT
+        ? `${draftReply.slice(0, REVIEW_CONTEXT_LIMIT)}...`
+        : draftReply,
+    ].filter(Boolean).join('\n');
+
+    try {
+      const reviewerModel = providerName === 'gemini' ? MODELS.REVIEWER : modelName;
+      const review = await provider.generateResponse(
+        reviewerModel,
+        'You are a strict final reviewer. Do not call tools. Keep the output concise and follow the requested format exactly.',
+        [{ role: 'user', parts: [{ text: reviewPrompt }] }],
+      );
+
+      if (review.usage) {
+        stats.totalTokens += review.usage.totalTokens;
+      }
+
+      const decision = parseReviewerDecision(stripThinkTags(review.text || ''));
+      if (decision.verdict === 'pass') {
+        return draftReply;
+      }
+
+      if (decision.revisedReply) {
+        log.info('Reviewer gate revised final response', { chatId, issues: decision.issues.length });
+        return stripThinkTags(decision.revisedReply);
+      }
+
+      const rewritePrompt = [
+        'Revise the assistant reply using the reviewer feedback below.',
+        'Return only the final user-facing reply.',
+        '',
+        '[Reviewer Issues]',
+        decision.issues.join('\n') || 'Tighten correctness and completeness.',
+        '',
+        '[Original Reply]',
+        draftReply,
+      ].join('\n');
+
+      const rewrite = await provider.generateResponse(
+        modelName,
+        'Rewrite the assistant reply so it is clearer, more accurate, and fully aligned with the request. Do not call tools.',
+        [{ role: 'user', parts: [{ text: rewritePrompt }] }],
+      );
+
+      if (rewrite.usage) {
+        stats.totalTokens += rewrite.usage.totalTokens;
+      }
+
+      const revisedReply = stripThinkTags(rewrite.text || '').trim();
+      if (revisedReply) {
+        log.info('Reviewer gate rewrote final response', { chatId, issues: decision.issues.length });
+        return revisedReply;
+      }
+    } catch (err) {
+      const errMsg = String(err || '');
+      if (errMsg.includes('429') || errMsg.includes('Resource exhausted') || errMsg.includes('Too Many Requests')) {
+        this.markProviderRateLimited(providerName);
+      }
+      log.warn('Reviewer gate skipped after review error', { chatId, error: String(err) });
+    }
+
+    return draftReply;
+  }
