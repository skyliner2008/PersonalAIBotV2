+/**
+ * Strip invisible control characters, emoji, and markdown formatting
+ * for Gemini Live API. The native-audio-preview model has trouble with
+ * emoji/special chars in tool response text โ€” they arrive as mojibake.
+ */
+function sanitizeForLiveApi(text: string): string {
+  return text
+    // Remove emoji (Supplementary Multilingual Plane + common emoji blocks)
+    .replace(/[\u{1F300}-\u{1FAFF}\u{2600}-\u{27BF}\u{FE00}-\u{FE0F}\u{200D}\u{20E3}\u{E0020}-\u{E007F}]/gu, '')
+    // Remove zero-width characters
+    .replace(/[\u200B-\u200D\uFEFF\u00AD]/g, '')
+    // Remove control characters except newline and tab
+    .replace(/[\x00-\x08\x0B\x0C\x0E-\x1F\x7F]/g, '')
+    // Strip markdown formatting (bold, italic, headers, bullets)
+    .replace(/\*\*([^*]+)\*\*/g, '$1')    // **bold** โ’ bold
+    .replace(/\*([^*]+)\*/g, '$1')         // *italic* โ’ italic
+    .replace(/^#{1,6}\s+/gm, '')           // # headers
+    .replace(/^[\-*โ€ข]\s+/gm, '- ')         // bullet chars โ’ simple dash
+    .replace(/```[\s\S]*?```/g, '')         // code blocks
+    .replace(/`([^`]+)`/g, '$1')           // inline code
+    // Normalize unicode to NFC (composed form)
+    .normalize('NFC')
+    .replace(/\n{3,}/g, '\n\n')            // collapse excessive newlines
+    .trim();
+}
