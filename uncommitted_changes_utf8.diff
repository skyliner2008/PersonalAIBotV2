+
+function extractLiveToolCommand(args: unknown): string {
+  if (args == null) return '';
+  if (typeof args === 'string') {
+    const raw = args.trim();
+    if (!raw) return '';
+    try {
+      const parsed = JSON.parse(raw);
+      if (parsed && typeof parsed === 'object' && 'command' in parsed) {
+        return String((parsed as { command?: unknown }).command ?? '')
+          .replace(/\s+/g, ' ')
+          .trim()
+          .slice(0, 4000);
+      }
+    } catch {
+      // raw string command fallback โ€” not JSON, treat as plain text
+    }
+    return raw.replace(/\s+/g, ' ').trim().slice(0, 4000);
+  }
+  if (typeof args === 'object' && 'command' in (args as Record<string, unknown>)) {
+    return String((args as { command?: unknown }).command ?? '')
+      .replace(/\s+/g, ' ')
+      .trim()
+      .slice(0, 4000);
+  }
+  if (typeof args === 'object' && 'fields' in (args as Record<string, unknown>)) {
+    const fields = (args as { fields?: Record<string, unknown> }).fields;
+    const commandField = fields && typeof fields === 'object'
+      ? (fields.command as { stringValue?: unknown } | undefined)
+      : undefined;
+    return String(commandField?.stringValue ?? '')
+      .replace(/\s+/g, ' ')
+      .trim()
+      .slice(0, 4000);
+  }
+  return '';
+}
