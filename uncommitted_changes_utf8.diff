+        client.connect();
+        liveClients.set(socket.id, client);
+
+      } catch (err: any) {
+        console.error('[Socket] voice:start error:', err);
+        try { ack?.({ ok: false, error: String(err?.message || err || 'voice:start failed') }); } catch { /* ignore */ }
+        socket.emit('voice:error', { message: err.message });
+      }
+    });
+
+    socket.on('voice:text_input', (data: { text?: string }) => {
+      // Notify self-upgrade system that user is active
+      notifyUserActivity();
+
+      const rawText = String(data?.text || '').trim();
+      const text = rawText.replace(/\s+/g, ' ').trim().slice(0, 4000);
+      if (!text) return;
+
+      // Save user message to AI memory
+      saveVoiceToMemory(socket.id, 'user', text);
+
+      // โ”€โ”€โ”€ Detect @mention CLI routing โ”€โ”€โ”€
+      // Supports: @gemini @claude @codex @kilo @jarvis @all
+      // Multi-dispatch: "@gemini @claude เธชเธฃเธธเธเธเนเธญเธกเธนเธฅ" โ’ dispatches to both
+      const mentionPattern = /@([a-zA-Z0-9_-]+)/g;
+      const mentions: string[] = [];
+      let match: RegExpExecArray | null;
+      while ((match = mentionPattern.exec(text)) !== null) {
+        mentions.push(match[1].toLowerCase());
+      }
+
+      // Strip @mentions from the prompt to get clean message
+      const cleanMessage = text.replace(/@[a-zA-Z0-9_-]+\s*/g, '').trim();
+
+      // Determine which backends to use
+      const isMultiDispatch = mentions.length > 0 && mentions.some(m => m !== 'jarvis' && m !== 'agent' && m !== 'admin');
+      const hasAllMention = mentions.includes('all');
+
+      if (hasAllMention) {
+        // โ”€โ”€โ”€ Meeting Room mode: Jarvis as supervisor โ”€โ”€โ”€
+        // @all โ’ Jarvis decomposes โ’ CLIs work โ’ Jarvis reviews โ’ summary
+        queueVoiceAgentTask(socket.id, async () => {
+          socket.emit('voice:agent_status', { status: 'processing' });
+          try {
+            const message = cleanMessage || text;
+            addLog('voice', 'Meeting Room', `@all ${message.slice(0, 150)}`, 'info');
+
+            const availableCLIs = ['gemini', 'claude', 'codex', 'kilo'];
+            const summary = await runMeetingRoom({
+              socket,
+              message,
+              availableCLIs,
+              userId: buildVoiceUserId(socket.id),
+              maxReviewRounds: 1,
+            });
+
+            socket.emit('voice:agent_reply', { input: text, reply: summary });
+            socket.emit('voice:text_recv', { text: `๐‘‘ **Meeting Room เธชเธฃเธธเธ:**\n\n${summary}`, source: 'agent' });
+            saveVoiceToMemory(socket.id, 'assistant', summary);
+          } catch (err: any) {
+            const message = err?.message || String(err);
+            log.error('[MeetingRoom] failed', { socketId: socket.id, error: message });
+            socket.emit('voice:agent_reply', { input: text, reply: `Meeting Room error: ${message}` });
+          } finally {
+            socket.emit('voice:agent_status', { status: 'idle' });
+          }
+        });
+      } else if (isMultiDispatch) {
+        // โ”€โ”€โ”€ Multi-CLI parallel dispatch (e.g. @gemini @claude) โ”€โ”€โ”€
+        // Direct dispatch without supervisor โ€” each CLI gets same question
+        queueVoiceAgentTask(socket.id, async () => {
+          socket.emit('voice:agent_status', { status: 'processing' });
+          try {
+            const message = cleanMessage || text;
+            const targets = [...new Set(mentions)];
+            addLog('voice', 'Multi-CLI dispatch', `[${targets.join(',')}] ${message.slice(0, 150)}`, 'info');
+
+            const dispatchPromises = targets.map(async (target) => {
+              const prefix = target === 'jarvis' || target === 'agent' || target === 'admin'
+                ? `@agent ${message}`
+                : `@${target} ${message}`;
+              try {
+                const result = await executeCommand(prefix, 'web', buildVoiceUserId(socket.id));
+                return { target, output: String(result || '').trim(), status: 'success' as const };
+              } catch (err: any) {
+                return { target, output: String(err?.message || err || 'error'), status: 'error' as const };
+              }
+            });
+
+            const results = await Promise.allSettled(dispatchPromises);
+            const parts: string[] = [];
+
+            for (const r of results) {
+              if (r.status === 'fulfilled') {
+                const { target, output, status: resultStatus } = r.value;
+                const icon = target === 'jarvis' ? '๐‘‘' : target === 'gemini' ? '๐”ท' : target === 'claude' ? '๐ก' : target === 'codex' ? '๐ข' : 'โช';
+                if (resultStatus === 'success' && output) {
+                  parts.push(`${icon} @${target.toUpperCase()}:\n${output}`);
+                  socket.emit('voice:cli_reply', { agent: target, reply: output, status: 'success' });
+                } else {
+                  parts.push(`${icon} @${target.toUpperCase()}: โ ${output || 'No response'}`);
+                  socket.emit('voice:cli_reply', { agent: target, reply: output || 'No response', status: 'error' });
+                }
+              }
+            }
+
+            const fullReply = parts.join('\n\n---\n\n') || 'เนเธกเนเธกเธต CLI เธ•เธญเธเธเธฅเธฑเธ';
+            socket.emit('voice:agent_reply', { input: text, reply: fullReply });
+            socket.emit('voice:text_recv', { text: fullReply, source: 'agent' });
+            saveVoiceToMemory(socket.id, 'assistant', fullReply);
+          } catch (err: any) {
+            const errMsg = err?.message || String(err);
+            log.error('[VoiceAgent] multi-dispatch failed', { socketId: socket.id, error: errMsg });
+            socket.emit('voice:agent_reply', { input: text, reply: `Multi-CLI error: ${errMsg}` });
+          } finally {
+            socket.emit('voice:agent_status', { status: 'idle' });
+          }
+        });
+      } else if (mentions.length === 1 && mentions[0] !== 'jarvis' && mentions[0] !== 'agent') {
+        // Single CLI dispatch (e.g. "@gemini เธชเธงเธฑเธชเธ”เธต")
+        const target = mentions[0];
+        const message = cleanMessage || text;
+        queueVoiceAgentTask(socket.id, async () => {
+          socket.emit('voice:agent_status', { status: 'processing' });
+          try {
+            addLog('voice', `CLI dispatch: @${target}`, message.slice(0, 200), 'info');
+            const result = await executeCommand(`@${target} ${message}`, 'web', buildVoiceUserId(socket.id));
+            const reply = String(result || '').trim() || `@${target} เนเธกเนเธกเธตเธเธฒเธฃเธ•เธญเธเธเธฅเธฑเธ`;
+            socket.emit('voice:cli_reply', { agent: target, reply, status: 'success' });
+            socket.emit('voice:agent_reply', { input: text, reply });
+            socket.emit('voice:text_recv', { text: reply, source: 'agent' });
+            saveVoiceToMemory(socket.id, 'assistant', reply);
+          } catch (err: any) {
+            const message = err?.message || String(err);
+            log.error(`[VoiceAgent] @${target} dispatch failed`, { socketId: socket.id, error: message });
+            socket.emit('voice:agent_reply', { input: text, reply: `@${target} error: ${message}` });
+          } finally {
+            socket.emit('voice:agent_status', { status: 'idle' });
+          }
+        });
+      } else {
+        // Default: route to Jarvis Agent (no @mentions or @jarvis)
+        queueVoiceAgentTask(socket.id, async () => {
+          socket.emit('voice:agent_status', { status: 'processing' });
+          try {
+            addLog('voice', 'Jarvis voice input', text.slice(0, 200), 'info');
+            const result = await executeVoiceAgentCommandWithPolicy(text, socket.id, true);
+            const reply = String(result || '').trim() || 'No response from Jarvis.';
+            socket.emit('voice:agent_reply', { input: text, reply });
+            socket.emit('voice:text_recv', { text: reply, source: 'agent' });
+            saveVoiceToMemory(socket.id, 'assistant', reply);
+          } catch (err: any) {
+            const message = err?.message || String(err);
+            log.error('[VoiceAgent] command execution failed', { socketId: socket.id, error: message });
+            socket.emit('voice:agent_reply', { input: text, reply: `Voice agent error: ${message}` });
+          } finally {
+            socket.emit('voice:agent_status', { status: 'idle' });
+          }
+        });
+      }
+    });
+
+    socket.on('voice:audio_send', (data: { audio: string }) => {
+        const client = liveClients.get(socket.id);
+        if (client && client.isConnected) {
+            client.sendAudioChunk(data.audio);
+        }
+    });
+
+    socket.on('voice:ping', () => {
+      socket.emit('voice:pong', { ts: Date.now() });
+    });
+
+    socket.on('voice:stop', (payload?: { reason?: string }) => {
+        log.info('[LiveVoice] Stop requested by client', {
+          socketId: socket.id,
+          reason: String(payload?.reason || 'unknown'),
+        });
+        voiceAgentQueues.delete(socket.id);
+        socket.emit('voice:agent_status', { status: 'idle' });
+        const client = liveClients.get(socket.id);
+        if (client) {
+            client.signalAudioStreamEnd();
+            client.disconnect();
+            liveClients.delete(socket.id);
+        }
+    });
+
     // ========== Disconnect ==========
-    socket.on('disconnect', () => {
-      console.log(`[Socket] Client disconnected: ${socket.id}`);
+    socket.on('disconnect', (reason) => {
+      log.debug(`[Socket] Client disconnected: ${socket.id}`, { reason });
+      voiceAgentQueues.delete(socket.id);
+      
+      const client = liveClients.get(socket.id);
+      if (client) {
+          client.signalAudioStreamEnd();
+          client.disconnect();
+          liveClients.delete(socket.id);
+      }
     });
   });
 }
