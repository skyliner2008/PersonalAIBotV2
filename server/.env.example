# Environment Variables Configuration
# Copy this file to .env and fill in your values

# ===================
# Server Configuration
# ===================
PORT=3000
NODE_ENV=development
# Reverse-proxy trust setting (important when using ngrok/cloudflare tunnel)
# development default in code is 1, production default is false.
# TRUST_PROXY=1
# Allow remote /api/auth/socket-token for mobile/ngrok dashboard access (0/1)
# SOCKET_TOKEN_ALLOW_REMOTE=1

# ===================
# Logging
# ===================
# Console log level: error | warn | info | debug
LOG_LEVEL=info
# HTTP console verbosity: errors | important | all
HTTP_CONSOLE_MODE=errors
# Verbose swarm internals (0/1)
SWARM_VERBOSE_LOGS=0
# Optional: enable second-pass follow-up prompts per CLI lane (A->B stages)
# 0 = single-pass (default, lower token usage), 1 = multi-pass
JARVIS_MULTIPASS=0
# Jarvis delegation mode:
# 1 = send concise direct task payloads to CLI lanes (recommended)
# 0 = use legacy verbose delegation templates
JARVIS_TERMINAL_DIRECT_MODE=1
# Optional English objective handoff (disabled by default for speed/stability)
JARVIS_ENABLE_ENGLISH_HANDOFF=0
# Swarm CLI lane config (recommended defaults for stability)
# Total task timeout per delegated CLI task (ms)
SWARM_CLI_TASK_TIMEOUT_MS=120000
# Send delegated tasks as shell-style CLI commands (gemini/codex/claude) from Jarvis
# 1 = shell-style command text (recommended), 0 = @prefix direct prompt mode
SWARM_CLI_SHELL_STYLE_MODE=1
# Use local deterministic synthesis for Jarvis final swarm summary (avoids provider 429 bottleneck)
SWARM_LOCAL_SYNTHESIS=1
# Enable supervisor-generated review/recovery follow-ups when lane output is weak or failed.
SWARM_ENABLE_SUPERVISOR_ACTIONS=1
# Allow supervisor to create cross-lane assist tasks (disabled by default to keep lane ownership stable)
SWARM_ENABLE_ASSIST_TASKS=0
# Allow supervisor to cancel a slow lane and hand over to a faster completed lane
SWARM_ENABLE_PREEMPTIVE_REROUTE=1
# Minimum processing time before assist is considered (ms)
SWARM_ASSIST_SLOW_TASK_MS=20000
# Hard cap for supervisor follow-up rounds per batch (controls token usage)
SWARM_MAX_SUPERVISOR_FOLLOWUPS=2
# Maximum number of Stage-A analysis lanes planned automatically
JARVIS_MAX_STAGE_A_LANES=5
# Adaptive retry strategy for CLI dispatch:
# number of command-style attempts per task (1-3)
SWARM_CLI_ADAPTIVE_MAX_ATTEMPTS=2
# extra timeout added per next attempt (ms)
SWARM_CLI_ADAPTIVE_TIMEOUT_STEP_MS=45000
# Command execution timeout used by swarm one-shot calls (ms)
SWARM_COMMAND_TIMEOUT_MS=120000
# Timeout used by persistent lanes if enabled (ms)
SWARM_LANE_TIMEOUT_MS=120000
# Persistent swarm lanes: 0=off (recommended), 1=on
SWARM_PERSISTENT_CLI=0
# Skip extra Agent reviewer/background passes for swarm chat IDs to reduce quota pressure
SWARM_SKIP_REVIEWER_GATE=1
SWARM_SKIP_BACKGROUND_ENRICHMENT=1

# ===================
# Rate Limiting
# ===================
# Time window in milliseconds (default: 900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Maximum requests per IP per window (default: 100)
RATE_LIMIT_MAX=100

# ===================
# Encryption
# ===================
# IMPORTANT: Change this to a secure 32-byte key in production!
# Generate a secure key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-hex-key-here-change-me

# ===================
# AI Providers (Examples)
# ===================
# OpenAI
OPENAI_API_KEY=sk-...

# Google Gemini
GEMINI_API_KEY=AIza...
# Embedding model routing (supports Gemini Embedding 1 + 2 fallback)
# Option A: Explicit ordered chain (recommended)
# GEMINI_EMBEDDING_MODELS=gemini-embedding-002,gemini-embedding-001
# Option B: Primary + fallback list
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# GEMINI_EMBEDDING_FALLBACK_MODELS=gemini-embedding-002,text-embedding-004,gemini-embedding-001
# Live voice websocket API version and preferred model (resolved dynamically if available)
GEMINI_LIVE_API_VERSION=v1beta
# GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
# GEMINI_LIVE_MODEL_CANDIDATES=gemini-2.5-flash-native-audio-preview-12-2025,gemini-2.5-flash-native-audio-preview-09-2025,gemini-2.5-flash-live-preview,gemini-2.0-flash-live-001

# Minimax
MINIMAX_API_KEY=...

# ===================
# Messaging Platforms
# ===================
# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
ADMIN_TELEGRAM_IDS=123456789

# LINE
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-access-token
ADMIN_LINE_IDS=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Facebook
FACEBOOK_PAGE_ACCESS_TOKEN=your-facebook-token
FACEBOOK_VERIFY_TOKEN=your-verify-token

# ===================
# Database
# ===================
# SQLite is used by default (stored in data/ directory)

# ===================
# Playwright
# ===================
HEADLESS=false
SLOW_MO=0

# ===================
# Optional CLI Bridges (Boss Mode)
# ===================
# If command discovery picks a non-runnable path on Windows, set explicit paths.
GEMINI_CLI_PATH=
CODEX_CLI_PATH=
CLAUDE_CLI_PATH=
