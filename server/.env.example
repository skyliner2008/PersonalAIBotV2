# ============================================================
# PersonalAIBotV2 — Server Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000
DB_PATH=./data/fb-agent.db

# ── AI Providers ────────────────────────────────────────────
# Required: Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: OpenAI-compatible providers
OPENAI_API_KEY=your_openai_api_key_here
MINIMAX_API_KEY=your_minimax_api_key_here

# ── Facebook Automation ─────────────────────────────────────
# Facebook login credentials (stored obfuscated in DB after first login)
FB_EMAIL=your_facebook_email@gmail.com
FB_PASSWORD=your_facebook_password

# ── Telegram Bot ────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── LINE Bot ─────────────────────────────────────────────────
# Get from LINE Developers Console (https://developers.line.biz)
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# ── Security ─────────────────────────────────────────────────
# Secret for credential obfuscation (change from default!)
CRED_SECRET=change-this-to-a-random-secret-string

# ── Ngrok (optional, for LINE webhook) ───────────────────────
# Set this if not using ngrok auto-detection
# PUBLIC_URL=https://your-domain.com
