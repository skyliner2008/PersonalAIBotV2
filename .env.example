# ============================================================
# PersonalAIBotV2 - Environment Configuration
# Copy this file to .env and fill in the values
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000

# ── Security (REQUIRED for production) ──────────────────────
JWT_SECRET=                    # Random string 32+ chars for JWT signing
ADMIN_USER=admin               # Dashboard admin username
ADMIN_PASSWORD=                # Dashboard admin password (REQUIRED)
SOCKET_AUTH_TOKEN=             # Token for WebSocket auth
ENCRYPTION_KEY=                # 32-char key for AES-256-GCM encryption
CRED_SECRET=                   # Credential store encryption secret (auto-generated if empty)

# ── AI Providers ────────────────────────────────────────────
GEMINI_API_KEY=                # Google Gemini API key (primary provider)
# Additional providers can be configured via dashboard

# ── Channel Bots ────────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=     # LINE Bot channel access token
LINE_CHANNEL_SECRET=           # LINE Bot channel secret
TELEGRAM_BOT_TOKEN=            # Telegram Bot token from @BotFather

# ── CLI Paths (optional, auto-detected) ────────────────────
# GEMINI_CLI_PATH=             # Path to Gemini CLI binary
# CODEX_CLI_PATH=              # Path to Codex CLI binary
# CLAUDE_CLI_PATH=             # Path to Claude CLI binary

# ── Logging & Debug ────────────────────────────────────────
LOG_LEVEL=info                 # info | debug | warn | error
HTTP_CONSOLE_MODE=errors       # errors | all | silent
STARTUP_COMPACT=1              # 1 = cleaner startup logs, 0 = verbose
SWARM_VERBOSE_LOGS=0           # 1 = detailed swarm logs

# ── Swarm / Multi-Agent ────────────────────────────────────
JARVIS_MULTIPASS=0             # 1 = enable multi-pass planning (costs more tokens)

# ── Rate Limiting ──────────────────────────────────────────
# RATE_LIMIT_WINDOW_MS=900000 # 15 minutes default
# RATE_LIMIT_MAX=100           # Max requests per window

# ── Browser Automation (optional) ──────────────────────────
# HEADLESS=true                # true = hide browser, false = show
# SLOW_MO=0                   # Slow down automation (ms)

# ── Remote Access (optional) ───────────────────────────────
# SOCKET_TOKEN_ALLOW_REMOTE=0 # 1 = allow remote socket token requests
